# HA runtime state, secrets, and generated artifacts (written LIVE on the box).
# Must NOT be tracked — git_pull does `reset --hard`, which would otherwise
# overwrite the live token / sensor baselines with stale committed copies.
c4_token_cache.txt            # Control4 director bearer token (secret + short-lived)
c4_door_visual_state.json     # visual sensor baseline (self-maintaining)
c4_entry_log_state.json       # entry-log state (self-maintaining)
